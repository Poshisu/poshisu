# =============================================================================
# Nourish — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — https://supabase.com/dashboard/project/<your-ref>/settings/api
# -----------------------------------------------------------------------------

# Your Supabase project URL (safe to expose publicly)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase anon/publishable key (safe to expose publicly — enforced by RLS)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key — NEVER expose this client-side
# Used only in server-side code and edge functions
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# Anthropic Claude API — https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------

# Claude API key — server-side only, never expose publicly
ANTHROPIC_API_KEY=sk-ant-api03-...

# -----------------------------------------------------------------------------
# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
# Used for Scribe v2 voice transcription (best Hinglish accuracy)
# -----------------------------------------------------------------------------

ELEVENLABS_API_KEY=sk_...

# -----------------------------------------------------------------------------
# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
# -----------------------------------------------------------------------------

# Public VAPID key — safe to expose, sent to browser for push subscription
VAPID_PUBLIC_KEY=BN...
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BN...

# Private VAPID key — server-side only
VAPID_PRIVATE_KEY=...

# VAPID subject — your contact email or app URL
VAPID_SUBJECT=mailto:hello@nourish.app

# -----------------------------------------------------------------------------
# PostHog — https://app.posthog.com/project/settings
# -----------------------------------------------------------------------------

# PostHog project API key (safe to expose publicly)
NEXT_PUBLIC_POSTHOG_KEY=phc_...

# PostHog host (use https://app.posthog.com or your self-hosted URL)
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# PostHog private API key — server-side only, for server-side event capture
POSTHOG_PRIVATE_KEY=phx_...

# -----------------------------------------------------------------------------
# Sentry — https://sentry.io/settings/<org>/projects/<project>/keys/
# -----------------------------------------------------------------------------

# Sentry DSN — safe to expose publicly
NEXT_PUBLIC_SENTRY_DSN=https://...@o....ingest.sentry.io/...

# Sentry auth token — build-time only (source maps upload)
# Generate at https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=sntrys_...

# Sentry org and project slugs — used by sentry/nextjs for source map upload
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=nourish

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

# Public URL of your deployed app (used for push notification endpoints, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
